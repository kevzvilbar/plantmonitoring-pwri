# Copy to .env.local for local development.
# On Render (static site), set these as environment variables in the dashboard or render.yaml.

VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<your-supabase-anon-key>

# Render backend service URL (no trailing slash).
# Leave empty to use relative /api paths (only works if frontend and backend
# share the same domain / Render internal routing).
# Production example: https://pwri-backend.onrender.com
VITE_BACKEND_URL=
