# Copy this file to .env and fill in real values for local development.
# On Render, set these as environment variables in the dashboard or render.yaml.

# ── MongoDB ────────────────────────────────────────────────────────────────
MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
DB_NAME=pwri

# ── Supabase ───────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-supabase-anon-key>

# ── OpenAI ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Cron / scheduled jobs ──────────────────────────────────────────────────
CRON_SECRET=<random-secret-for-cron-endpoints>

# ── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Local dev:  http://localhost:5000,http://127.0.0.1:5000
# Production: https://pwri-frontend.onrender.com
CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000
